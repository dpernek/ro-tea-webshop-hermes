# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:***@db.xxxxxx.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:***@db.xxxxxx.supabase.co:5432/postgres"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbG..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbG..."

# Supabase Storage bucket for image uploads
SUPABASE_STORAGE_BUCKET="images"
UPLOAD_PROVIDER="supabase-storage"

# Cloudinary (only if UPLOAD_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_UPLOAD_PRESET="ro-tea"

# NextAuth
AUTH_SECRET=...n
ADMIN_EMAIL=*** Stripe
STRIPE_SECRET_KEY="sk_t...n
# Microsoft 365 Email (Microsoft Graph API)
EMAIL_PROVIDER="microsoft-graph"
MICROSOFT_TENANT_ID="00000000-0000-0000-0000-000000000000"
MICROSOFT_CLIENT_ID="00000000-0000-0000-0000-000000000000"
MICROSOFT_CLIENT_SECRET="..."
MICROSOFT_SENDER_USER="info@ro-tea.hr"
ORDER_NOTIFICATION_EMAIL="info@ro-tea.hr"

# GLS Croatia shipping integration (optional — requires GLS account)
# Set GLS_TEST_MODE=false to use production GLS API
GLS_TEST_MODE=true
GLS_API_BASE_URL="https://api.test.mygls.hr"
GLS_USERNAME=""
GLS_PASSWORD=""
GLS_CLIENT_NUMBER=""
GLS_COUNTRY_CODE="HR"

# Public URL
NEXT_PUBLIC_SITE_URL="https://ro-tea-webshop-hermes.vercel.app"
