# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:***@db.xxxxxx.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:***@db.xxxxxx.supabase.co:5432/postgres"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbG..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbG..."

# Supabase Storage bucket for image uploads
SUPABASE_STORAGE_BUCKET="images"

# Upload provider: "supabase-storage" (default, recommended), "cloudinary", "local" (dev only)
UPLOAD_PROVIDER="supabase-storage"

# Cloudinary (only needed if UPLOAD_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_UPLOAD_PRESET="ro-tea"

# NextAuth
AUTH_SECRET="change-me-to-random-64-chars"
AUTH_URL="http://localhost:3000"

# Admin seed credentials
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Email (Resend)
RESEND_API_KEY="re_..."
ADMIN_ORDER_EMAIL="orders@example.com"
EMAIL_FROM="RO-TEA <info@ro-tea.hr>"

# Public URL
NEXT_PUBLIC_SITE_URL="https://ro-tea-webshop-hermes.vercel.app"
